{
  "name": "@wirevice/sluice-mock",
  "description": "A mock stream server for testing ABR and behavior logic in media players and monitoring tools",
  "version": "0.3.5",
  "bin": {
    "sluice-mock": "bin/sluice-mock.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevenlyons/sluice-mock.git"
  },
  "bugs": {
    "url": "https://github.com/stevenlyons/sluice-mock/issues"
  },
  "homepage": "https://github.com/stevenlyons/sluice-mock#readme",
  "license": "MIT",
  "keywords": [
    "hls",
    "dash",
    "abr",
    "video",
    "audio",
    "mock",
    "testing",
    "player"
  ],
  "files": [
    "app.js",
    "lib/logic.js",
    "lib/manifest.js",
    "media/",
    "bin/"
  ],
  "config": {
    "port": "3030",
    "specs": "specs"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node bin/sluice-mock.js",
    "dev": "node --watch bin/sluice-mock.js",
    "test": "node --test lib/logic.test.js lib/manifest.test.js app.test.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "big.js": "^7.0.1",
    "koa": "^3.1.2",
    "koa-throttle2": "^3.1.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  }
}
