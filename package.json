{
  "name": "sluice-mock",
  "description": "A mock stream server for testing ABR and behavior logic in media players and monitoring tools",
  "version": "0.3.0",
  "bin": {
    "sluice-mock": "./bin/sluice-mock.js"
  },
  "repository": "github:stevenlyons/sluice-mock",
  "bugs": {
    "url": "https://github.com/stevenlyons/sluice-mock/issues"
  },
  "homepage": "https://github.com/stevenlyons/sluice-mock#readme",
  "license": "MIT",
  "keywords": ["hls", "dash", "abr", "video", "audio", "mock", "testing", "player"],
  "files": [
    "app.js",
    "lib/",
    "media/",
    "bin/",
    "specs/"
  ],
  "config": {
    "port": "3030",
    "specs": "specs"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node app.js",
    "dev": "node --watch app.js",
    "test": "node --test lib/logic.test.js lib/manifest.test.js app.test.js"
  },
  "dependencies": {
    "koa": "^3.1.2",
    "koa-throttle2": "^3.1.8"
  }
}
